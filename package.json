{
  "name": "constell",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Lightweight open-source LLM observability platform",
  "author": "Constell Team",
  "license": "MIT",
  "engines": {
    "node": "26",
    "pnpm": ">=11.1.3"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "turbo run build",
    "build:check": "turbo run build:check",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:worker": "turbo run dev --filter=worker",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "tc": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,yml,yaml}\"",
    "infra:dev:up": "docker compose --env-file ./infra/versions.env -f ./docker-compose.dev.yml up -d --wait",
    "infra:dev:down": "docker compose --env-file ./infra/versions.env -f ./docker-compose.dev.yml down",
    "infra:dev:prune": "docker compose --env-file ./infra/versions.env -f ./docker-compose.dev.yml down -v",
    "dx": "pnpm install && pnpm run infra:dev:up && echo 'Infrastructure ready. Run: pnpm run dev'",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "postinstall": "bash scripts/postinstall.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
