{
  "name": "@constell/shared",
  "version": "0.2.0-alpha",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src/server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./src/db": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./src/env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./src/encryption": {
      "types": "./dist/encryption/index.d.ts",
      "default": "./dist/encryption/index.js"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "echo 'lint: skip (no eslint config yet)'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "ch:reset": "echo 'ClickHouse reset: placeholder'",
    "db:seed:examples": "prisma db seed"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.5",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^22.15.0",
    "ioredis": "^5.10.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  }
}
